---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CompareTable from '../components/CompareTable.astro';
import DifferentiatorList from '../components/DifferentiatorList.astro';
import SpecLinks from '../components/SpecLinks.astro';
import CtaBand from '../components/CtaBand.astro';
---

<BaseLayout
  title="iOS / Android / Agent OS"
  description="A cited comparison of iOS, Android and Agent OS across fourteen dimensions, including object model, interface composition, agent authority, peer connectivity, privacy, history and distribution."
>
  <PageHeader
    eyebrow="Evidence map · AOS-RES-013"
    title="iOS, Android, and Agent OS — on the record."
    lede="An evidence map, not a feature-scoreboard. iOS and Android cells point to vendor security or developer material; Agent OS cells point to canonical target specifications. Inferences are labelled as such."
  />

  <section class="section border-b border-border">
    <div class="mx-auto max-w-6xl px-6">
      <CompareTable />
    </div>
  </section>

  <section class="section border-b border-border">
    <div class="mx-auto max-w-6xl px-6">
      <SectionHeader
        eyebrow="The structural wagers"
        title="What Agent OS changes below the feature layer."
        lede="The incumbents already have typed intents, widgets, on-device AI and nearby sharing. Agent OS makes different units primary: shared entities, user-composed micro-apps, semantic receipts and transport-neutral peer delivery."
      />
      <div class="mt-12"><DifferentiatorList /></div>
    </div>
  </section>

  <section class="section border-b border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-4 lg:grid-cols-2">
        <article class="rounded-xl border border-border bg-card p-6 sm:p-8">
          <div class="eyebrow mb-3">Interface composition</div>
          <h2 class="text-xl font-semibold tracking-tight">A missing interface is not automatically a missing app.</h2>
          <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
            The <a href="/micro-apps" class="text-signal hover:underline">text-to-micro-app builder</a> composes declared data, actions, views and policy into one inspectable instance that can render inside AI, documents, notifications, widgets or focused modes.
          </p>
        </article>
        <article class="rounded-xl border border-border bg-card p-6 sm:p-8">
          <div class="eyebrow mb-3">Peer connectivity</div>
          <h2 class="text-xl font-semibold tracking-tight">Nearby and off-grid delivery share one system model.</h2>
          <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
            <a href="/mesh" class="text-signal hover:underline">Agent Mesh</a> uses one signed envelope and receipt model across direct IP, Wi-Fi, Bluetooth, LoRa, gateways and delayed relays instead of fragmenting identity and status by transport.
          </p>
        </article>
      </div>

      <div class="mt-10">
        <SpecLinks
          heading="Primary Agent OS specifications"
          links={[
            { label: 'AOS-ARCH-009 · Entity graph, history, sync & bundles', path: 'engineering-bible/docs/architecture/AOS-ARCH-009.md' },
            { label: 'AOS-ARCH-010 · Agent runtime & action safety', path: 'engineering-bible/docs/architecture/AOS-ARCH-010.md' },
            { label: 'AOS-PROD-018 · Text-to-Micro-App Builder', path: 'engineering-bible/docs/product/PROD-018-text-to-micro-app-builder.md' },
            { label: 'AOS-ARCH-024 · Agent Mesh connectivity', path: 'engineering-bible/docs/architecture/ARCH-024-agent-mesh-connectivity.md' },
            { label: 'AOS-ARCH-026 · Micro-App Runtime', path: 'engineering-bible/docs/architecture/ARCH-026-micro-app-runtime.md' },
          ]}
        />
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>
