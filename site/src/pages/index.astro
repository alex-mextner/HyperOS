---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import PillarGrid from '../components/PillarGrid.astro';
import DifferentiatorList from '../components/DifferentiatorList.astro';
import CompareTable from '../components/CompareTable.astro';
import AudienceGrid from '../components/AudienceGrid.astro';
import StatusLedger from '../components/StatusLedger.astro';
import CtaBand from '../components/CtaBand.astro';
import Button from '../components/Button.astro';
import MicroApps from '../components/MicroApps.astro';
import AgentMeshTeaser from '../components/AgentMeshTeaser.astro';
import { compareDimensions } from '../data/compare';

const teaser = compareDimensions.filter((dimension) =>
  ['object-model', 'agent-authority', 'global-history', 'sandbox-caps'].includes(dimension.key)
);
---

<BaseLayout>
  <Hero />

  <section class="section border-b border-border">
    <div class="mx-auto max-w-6xl px-6">
      <SectionHeader
        eyebrow="The core shift"
        title="First-class work, not first-class apps."
        lede="The operating system owns durable semantics — identity, links, actions, authority, history, recovery and delivery. An application is only one replaceable provider or view."
      />
      <div class="mt-12"><PillarGrid /></div>
    </div>
  </section>

  <MicroApps />
  <AgentMeshTeaser />

  <section class="section border-b border-border">
    <div class="mx-auto max-w-6xl px-6">
      <SectionHeader
        eyebrow="Versus iOS & Android"
        title="A category difference, not a feature difference."
        lede="Agent OS changes the object, action, interface and authority models rather than adding another assistant or widget layer over application silos."
      />
      <div class="mt-12"><DifferentiatorList /></div>
    </div>
  </section>

  <section class="section border-b border-border">
    <div class="mx-auto max-w-6xl px-6">
      <SectionHeader
        eyebrow="Evidence, not slogans"
        title="Twelve axes, every claim cited."
        lede="Each iOS and Android cell cites a vendor security or developer source; each Agent OS target cites a canonical specification. Four axes are shown here."
      />
      <div class="mt-10"><CompareTable dimensions={teaser} /></div>
      <div class="mt-8"><Button href="/compare" variant="outline">See all twelve dimensions</Button></div>
    </div>
  </section>

  <section class="section border-b border-border">
    <div class="mx-auto max-w-6xl px-6">
      <SectionHeader
        eyebrow="Four ways in"
        title="One operating system. Choose your path."
        lede="Build the OS, build on it, back the thesis, or use it first. Each path opens the relevant product and engineering material."
      />
      <div class="mt-12"><AudienceGrid /></div>
    </div>
  </section>

  <section class="section border-b border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-10 lg:grid-cols-[1fr_1.2fr] lg:items-start">
        <SectionHeader
          eyebrow="Works today vs planned"
          title="What exists now, and what does not."
          lede="Agent OS is at bootstrap. The design is specified across product, connectivity and hardware tracks; implementation status remains explicit."
        />
        <StatusLedger />
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>
