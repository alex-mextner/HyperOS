      <rect x="24" y="58" width="252" height="116" rx="18" fill="#111827" stroke="#475569"/>
      <text x="44" y="88" fill="#f8fafc" font-size="15">“Show today’s UV index,</text>
      <text x="44" y="114" fill="#f8fafc" font-size="15">warn me before it gets high,</text>
      <text x="44" y="140" fill="#f8fafc" font-size="15">and add sunscreen actions.”</text>
      <rect x="24" y="188" width="125" height="18" rx="9" fill="#1d4ed8" opacity=".7"/>
      <rect x="159" y="188" width="84" height="18" rx="9" fill="#7c3aed" opacity=".62"/>
