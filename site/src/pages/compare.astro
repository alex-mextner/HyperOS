---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CompareTable from '../components/CompareTable.astro';
import DifferentiatorList from '../components/DifferentiatorList.astro';
import SpecLinks from '../components/SpecLinks.astro';
import CtaBand from '../components/CtaBand.astro';
---

<BaseLayout
  title="iOS / Android / Agent OS"
  description="A research-grade, cited comparison of iOS, Android and Agent OS across twelve dimensions — object model, agent authority, capabilities, global history, offline, privacy and more."
>
  <PageHeader
    eyebrow="Evidence map · AOS-RES-013"
    title="iOS, Android, and Agent OS — on the record."
    lede="An evidence map, not a marketing comparison. Every iOS/Android cell can be checked against a vendor security or developer document; every Agent OS cell against an internal specification. Where a claim rests on inference from documented behaviour, it says so."
  />

  <section class="section border-b border-border">
    <div class="mx-auto max-w-6xl px-6">
      <CompareTable />
    </div>
  </section>

  <section class="section border-b border-border">
    <div class="mx-auto max-w-6xl px-6">
      <SectionHeader
        eyebrow="The wagers"
        title="What Agent OS does differently."
        lede="The incumbents converged on typed action contracts and on-device-first AI — Agent OS adopts those. These are the bets it makes that they can't make without rebuilding their foundations."
      />
      <div class="mt-12">
        <DifferentiatorList />
      </div>
    </div>
  </section>

  <section class="section border-b border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="rounded-xl border border-border bg-card p-6 sm:p-8">
        <h2 class="text-xl font-semibold tracking-tight">Identity and distribution — designed, not deferred.</h2>
        <p class="mt-3 max-w-3xl text-sm leading-relaxed text-muted-foreground">
          The two rows above where the incumbents look mature — first-party identity and developer distribution — are
          <span class="text-foreground">the two Agent OS rethinks from first principles</span>, not gaps. Identity is a system-wide
          <a href="/how-it-works#global-account" class="text-signal hover:underline">Global Account</a>
          — one login, payments and data across web and native, with your data staying local. Distribution has
          <a href="/how-it-works#micro-apps" class="text-signal hover:underline">no App Store</a>
          — the system composes third-party micro-apps from what you are doing. Both are specified today.
        </p>
      </div>
      <div class="mt-10">
        <SpecLinks
          heading="Primary sources"
          links={[
            { label: 'AOS-RES-013 · Full comparison matrix', path: 'engineering-bible/docs/research/AOS-RES-013-os-comparison-matrix.md' },
            { label: 'AOS-ARCH-009 · Entity graph, history & sync', path: 'engineering-bible/docs/architecture/AOS-ARCH-009.md' },
            { label: 'AOS-ARCH-010 · Agent runtime & action safety', path: 'engineering-bible/docs/architecture/AOS-ARCH-010.md' },
            { label: 'ARCH-022 · Capability model', path: 'engineering-bible/docs/architecture/ARCH-022-layer-manifest-and-capabilities.md' },
          ]}
        />
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>
