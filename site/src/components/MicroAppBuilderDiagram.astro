    </g>

    <g transform="translate(936 390)" filter="url(#ma-shadow)">
      <rect width="210" height="108" rx="24" fill="#0f172a" stroke="#2dd4bf"/>
      <text x="20" y="29" fill="#5eead4" font-size="12" font-weight="700">LOCK / WATCH / AMBIENT</text>
      <circle cx="54" cy="70" r="22" fill="#134e4a"/><text x="54" y="77" text-anchor="middle" fill="#ccfbf1" font-size="20" font-weight="750">7</text>
